# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# Node
node_modules/
frontend/node_modules/

# Vite build output. Regenerated on every `npm run build` and
# picked up at runtime by server.py — cloners should run
# `cd frontend && npm install && npm run build` once before
# launching rsod-debug (server warns when dist is missing).
frontend/dist/
# TypeScript incremental build cache — purely local, thrashes on
# every typecheck.
*.tsbuildinfo

# Playwright MCP scratch: snapshot YAML and console logs dropped
# into .playwright-mcp/ while driving the browser during
# regression audits. Session-local and noisy.
.playwright-mcp/

# IDE
.vscode/
.idea/

# Claude memory/session context
.claude/

# OS
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.bak
CLAUDE.md

# Large binary fixture artifacts. PDB is 10 MB and regeneratable from the
# delldiags source tree via the SYMBOLS=YES build flag — see the fixture's
# BUILD.md for the exact commands.
tests/fixtures/psa_x64_forcecrash/*.pdb
